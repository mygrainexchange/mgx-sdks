{
    "name": "mygrainexchange/mgx-php",
    "version": "1.0.0",
    "description": "Official PHP client for the MGX Enterprise API. Browse anonymized inventory, place bids, read your team's trades and bids, manage cash bids, subscribe to webhooks, and read market prices. Authenticate with OAuth2 (Login with MGX). Seller identity is never exposed until a trade is paid on both sides.",
    "keywords": [
        "mygrainexchange",
        "mgx",
        "grain",
        "api",
        "sdk",
        "rest",
        "oauth2"
    ],
    "homepage": "https://developers.mygrainexchange.com",
    "license": "MIT",
    "authors": [
        {
            "name": "My Grain Exchange",
            "homepage": "https://mygrainexchange.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "MyGrainExchange\\Mgx\\Overlay\\": "overlay/",
            "MyGrainExchange\\Mgx\\": "lib/"
        },
        "files": [
            "overlay/WebhookVerifier.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MyGrainExchange\\Mgx\\Test\\": "test/"
        }
    }
}
